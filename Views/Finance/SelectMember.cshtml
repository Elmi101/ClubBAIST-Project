@{
    ViewData["Title"] = "Member Account Lookup";
}

<div class="page-header">
    <h2>Member Account</h2>
    <p class="page-subtitle">Look up a member's financial account</p>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-3">@ViewBag.Error</div>
}

<div class="panel" style="max-width:420px">
    <div class="panel-title">Member Lookup</div>
    <form method="get" action="/Finance/MyAccount">
        <div class="mb-4">
            <label class="form-label">Member Number</label>
            <input type="text" name="memberNumber"
                   class="form-control" placeholder="e.g. M001" />
        </div>
        <button type="submit"
                class="btn-action btn-action-dark"
                style="padding:10px 28px">
            View Account
        </button>
    </form>
</div>