@model ClubBAIST.Models.Domain.TeeTimeReservation

@{
    ViewData["Title"] = "Cancel Reservation";
    var dateStr = Model.Slot.TeeSheet?.SheetDate.ToString("yyyy-MM-dd")
                  ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="page-header">
    <h2>Cancel Reservation</h2>
    <p class="page-subtitle">
        @DateTime.Today.Add(Model.Slot.SlotTime).ToString("h:mm tt") —
        @Model.Slot.TeeSheet?.SheetDate.ToString("dddd, MMMM dd, yyyy")
    </p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-6">
        <div class="panel">
            <div class="panel-title">Reservation Details</div>
            <table class="baist-table" style="margin-bottom:0">
                <tr>
                    <td style="color:var(--mid);width:130px">Booked By</td>
                    <td><strong>@Model.BookedBy?.FullName</strong></td>
                </tr>
                <tr>
                    <td style="color:var(--mid)">Tee Time</td>
                    <td>
                        <strong style="font-family:'Cormorant Garamond',serif;
                                       font-size:1.1rem">
                            @DateTime.Today.Add(Model.Slot.SlotTime).ToString("h:mm tt")
                        </strong>
                    </td>
                </tr>
                <tr>
                    <td style="color:var(--mid)">Date</td>
                    <td>
                        @Model.Slot.TeeSheet?.SheetDate.ToString("MMMM dd, yyyy")
                    </td>
                </tr>
                <tr>
                    <td style="color:var(--mid)">Players</td>
                    <td>@Model.NumberOfPlayers</td>
                </tr>
                <tr>
                    <td style="color:var(--mid)">Carts</td>
                    <td>@Model.NumberOfCarts</td>
                </tr>
                <tr>
                    <td style="color:var(--mid)">Foursome</td>
                    <td>
                        @foreach (var p in Model.Players)
                        {
                            <span class="status-pill status-booked"
                                  style="margin:2px">
                                @(p.Member?.FullName ?? p.GuestName ?? "Guest")
                            </span>
                        }
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <div class="col-md-6">
        <div class="panel">
            <div class="panel-title">Confirm Cancellation</div>

            <div class="alert alert-warning mb-4">
                Per club rules, members are responsible for cancelling
                tee times they cannot make. Failure to cancel may result
                in a reprimand.
            </div>

            <form method="post" action="/Reservation/CancelConfirmed">
                @Html.AntiForgeryToken()
                <input type="hidden" name="reservationId"
                       value="@Model.ReservationId" />

                <div class="mb-4">
                    <label class="form-label">Your Member Number</label>
                    <input type="text" name="cancelledByMemberNumber"
                           class="form-control" placeholder="e.g. M001"
                           style="max-width:200px" />
                    <div class="form-text">
                        Enter your member number to confirm cancellation
                    </div>
                </div>

                <div style="display:flex;gap:0.75rem">
                    <button type="submit"
                            class="btn-action btn-action-danger"
                            style="padding:10px 28px">
                        Confirm Cancellation
                    </button>
                    <a href="/TeeSheet/ViewSheet?date=@dateStr"
                       class="btn-action btn-action-outline"
                       style="padding:10px 28px">
                        Go Back
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>