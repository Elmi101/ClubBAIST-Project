@model ClubBAIST.Models.ViewModels.ApplicationViewModel

@{
    ViewData["Title"] = "Membership Application";
}

<div class="page-header">
    <h2>Membership Application</h2>
    <p class="page-subtitle">Club BAIST — Private Golf Club</p>
</div>

@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
}

<form method="post" action="/Application/Apply">
    @Html.AntiForgeryToken()

    <!-- Personal Information -->
    <div class="panel">
        <div class="panel-title">Personal Information</div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">First Name *</label>
                <input type="text" name="FirstName" class="form-control"
                       placeholder="First name"
                       value="@Model.FirstName" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Last Name *</label>
                <input type="text" name="LastName" class="form-control"
                       placeholder="Last name"
                       value="@Model.LastName" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Date of Birth</label>
                <input type="date" name="DateOfBirth" class="form-control"
                       value="@Model.DateOfBirth?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Address *</label>
                <input type="text" name="Address" class="form-control"
                       placeholder="Street address"
                       value="@Model.Address" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Postal Code</label>
                <input type="text" name="PostalCode" class="form-control"
                       placeholder="T0A 0A0"
                       value="@Model.PostalCode" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-3 mb-3">
                <label class="form-label">Phone *</label>
                <input type="text" name="Phone" class="form-control"
                       placeholder="780-000-0000"
                       value="@Model.Phone" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Alternate Phone</label>
                <input type="text" name="AlternatePhone" class="form-control"
                       placeholder="780-000-0000"
                       value="@Model.AlternatePhone" />
            </div>
            <div class="col-md-5 mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="Email" class="form-control"
                       placeholder="email@example.com"
                       value="@Model.Email" />
                <div class="form-text">
                    Providing an email allows Club BAIST to send
                    monthly statements electronically
                </div>
            </div>
        </div>
    </div>

    <!-- Employment Information -->
    <div class="panel">
        <div class="panel-title">Employment Information</div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Occupation</label>
                <input type="text" name="Occupation" class="form-control"
                       placeholder="Your occupation"
                       value="@Model.Occupation" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Company Name</label>
                <input type="text" name="CompanyName" class="form-control"
                       placeholder="Company name"
                       value="@Model.CompanyName" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Company Phone</label>
                <input type="text" name="CompanyPhone" class="form-control"
                       placeholder="780-000-0000"
                       value="@Model.CompanyPhone" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Company Address</label>
                <input type="text" name="CompanyAddress" class="form-control"
                       placeholder="Company street address"
                       value="@Model.CompanyAddress" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Company Postal Code</label>
                <input type="text" name="CompanyPostalCode" class="form-control"
                       placeholder="T0A 0A0"
                       value="@Model.CompanyPostalCode" />
            </div>
        </div>
    </div>

    <!-- Desired Membership -->
    <div class="panel">
        <div class="panel-title">Desired Membership Type</div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Membership Type *</label>
                <select name="DesiredTypeId" class="form-select">
                    <option value="">— Select a membership type —</option>
                    @foreach (var type in Model.MembershipTypes)
                    {
                        <option value="@type.TypeId"
                                @(Model.DesiredTypeId == type.TypeId
                                                            ? "selected" : "")>
                        @type.DisplayName
                    </option>
                                        }
                </select>
            </div>
        </div>

        <div style="background:var(--cream);border:1px solid var(--border);
                    border-left:3px solid var(--gold);
                    padding:1.2rem 1.5rem;margin-top:0.5rem">
            <div style="font-size:0.65rem;letter-spacing:2.5px;
                        text-transform:uppercase;color:var(--gold);
                        margin-bottom:0.8rem;font-weight:500">
                Fee Schedule
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;
                        gap:0.4rem 2rem;font-size:0.82rem;
                        margin-bottom:0.6rem">
                <div>
                    <span style="color:var(--mid)">Share Purchase</span>
                    <span style="float:right;
                                 font-family:'Cormorant Garamond',serif;
                                 font-size:1rem;color:var(--dark)">
                        $1,000
                    </span>
                </div>
                <div>
                    <span style="color:var(--mid)">Entrance Fee</span>
                    <span style="float:right;
                                 font-family:'Cormorant Garamond',serif;
                                 font-size:1rem;color:var(--dark)">
                        $10,000
                    </span>
                </div>
            </div>
            <div style="font-size:0.75rem;color:var(--light-mid);
                        line-height:1.7">
                Entrance fee payable in 4 × $2,500 installments ·
                Annual fee due April 1 ·
                10% penalty on overdue balances ·
                Gold members: minimum $500/yr food & beverage charge
            </div>
        </div>
    </div>

    <!-- Sponsoring Members -->
    <div class="panel">
        <div class="panel-title">Sponsoring Members</div>
        <p style="font-size:0.82rem;color:var(--mid);
                  line-height:1.7;margin-bottom:1.5rem">
            Two existing Shareholder members must sponsor your application.
            Sponsors must have been members for at least 5 years,
            be in good standing, and may sponsor a maximum of
            2 applicants per year.
        </p>

        <div style="background:var(--cream);border:1px solid var(--border);
                    border-radius:2px;padding:1.2rem 1.5rem;
                    margin-bottom:1rem">
            <div style="font-size:0.65rem;letter-spacing:2px;
                        text-transform:uppercase;color:var(--mid);
                        font-weight:500;margin-bottom:0.8rem">
                Sponsor 1
            </div>
            <div class="row">
                <div class="col-md-4">
                    <label class="form-label">Member Number *</label>
                    <input type="text" name="Sponsor1MemberNumber"
                           class="form-control" placeholder="e.g. M001"
                           value="@Model.Sponsor1MemberNumber" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Signature</label>
                    <input type="text" name="Sponsor1Signature"
                           class="form-control"
                           placeholder="Type full name as signature"
                           value="@Model.Sponsor1Signature" />
                </div>
            </div>
        </div>

        <div style="background:var(--cream);border:1px solid var(--border);
                    border-radius:2px;padding:1.2rem 1.5rem">
            <div style="font-size:0.65rem;letter-spacing:2px;
                        text-transform:uppercase;color:var(--mid);
                        font-weight:500;margin-bottom:0.8rem">
                Sponsor 2
            </div>
            <div class="row">
                <div class="col-md-4">
                    <label class="form-label">Member Number *</label>
                    <input type="text" name="Sponsor2MemberNumber"
                           class="form-control" placeholder="e.g. M002"
                           value="@Model.Sponsor2MemberNumber" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Signature</label>
                    <input type="text" name="Sponsor2Signature"
                           class="form-control"
                           placeholder="Type full name as signature"
                           value="@Model.Sponsor2Signature" />
                </div>
            </div>
        </div>
    </div>

    <!-- Privacy & Submit -->
    <div class="panel">
        <div style="background:var(--cream);border:1px solid var(--border);
                    padding:1rem 1.2rem;margin-bottom:1.5rem">
            <div style="font-size:0.65rem;letter-spacing:2px;
                        text-transform:uppercase;color:var(--mid);
                        font-weight:500;margin-bottom:0.4rem">
                Privacy Notice
            </div>
            <p style="font-size:0.78rem;color:var(--light-mid);
                      line-height:1.8;margin:0">
                The information you provide on this application is requested
                strictly to update our membership data and the Membership
                Roster. This information will not be used for any other
                purpose except with your written permission.
            </p>
        </div>
        <div style="display:flex;gap:0.75rem;align-items:center">
            <button type="submit"
                    class="btn-action btn-action-dark"
                    style="padding:12px 40px">
                Submit Application
            </button>
            <a href="/Home/Index"
               class="btn-action btn-action-outline"
               style="padding:12px 40px">
                Cancel
            </a>
        </div>
    </div>

</form>